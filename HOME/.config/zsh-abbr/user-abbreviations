# -*- mode: shell-script -*-

abbr "e"="emacsclient --no-wait"
abbr "d"="date '+%Y-%m-%dT%H:%M:%S%z'"
abbr "g"="grep"
abbr "h"="history"

abbr "cp"="cp -i"
abbr "mv"="mv -i"
abbr "rm"="rm -i"

abbr "less"="less --LONG-PROMPT --LINE-NUMBERS"

abbr "tree"="tree -aCF -I .git"

abbr "npmjs"="open 'https://www.npmjs.com/package/@'"

abbr "firefox"="open -a Firefox"

abbr "image-optim"="open -a ImageOptim"

# ruby
abbr "be"="bundle exec"
abbr "rubygems"="open 'https://rubygems.org/gems/@'"

# git
abbr "ga"="git forgit add"
abbr "gb"="git forgit checkout_branch"
abbr "gbd"="git forgit branch_delete"
abbr "gbl"="git branch --all --format='%(HEAD) %(align:60)%(color:bold green)%(refname:short)%(color:reset)%(end)%09%(committerdate:relative)'"
abbr "gbn"="git switch --create"
abbr "gbr"="git branch --move"
abbr "gc"="git commit"
abbr "gce"="git commit --allow-empty --message 'chore: empty'"
abbr "gd"="git forgit diff HEAD"
abbr "gg"="git grep"
abbr "gl"="git forgit log"
abbr "glf"="git ls-files"
abbr "gm"="git merge --no-edit"
abbr "gp"="git push"
abbr "gs"="git status"
abbr "gwip"="git commit --no-verify --message 'chore: wip'"

# rg
abbr "rg"="rg --no-heading --hidden"

# lsd
abbr "lsd"="lsd --long --git"
abbr "ll"="lsd --long --git"

# https://github.com/ruby/un
abbr "web"="ruby -run -e httpd"

# GNU Time. Homebrew can install `gtime`. Ref https://formulae.brew.sh/formula/gnu-time
abbr "time"="gtime --portability"

# Docker
abbr "docker"="podman"
abbr "dockrun"='podman run --rm --interactive --tty --volume=${PWD}:/work --workdir=/work --network=host'

# most
abbr "man"="man -P most"
