[core]
	excludesfile = ~/.gitignore_global
	editor = emacsclient
	pager = delta --line-numbers
	commentChar = ~

[user]
	name = Masafumi Koba
	email = 473530+ybiquitous@users.noreply.github.com

[alias]
	# Clone
	fast-clone = clone --filter=blob:none

	# Branch
	default-branch = !"f() { \
		result=$(git symbolic-ref --short refs/remotes/origin/HEAD 2>&1); \
		if [ $? -ne 0 ]; then \
			echo ${result} >&2; \
			echo 'To resolve the error, try running: git remote set-head origin --auto' >&2; \
			return 1; \
		else \
			echo ${result} | sed 's#^origin/##'; \
		fi; \
	}; f"

	# Tag
	delete-tag = !"f() { git push --delete $(git origin) $1 && git tag --delete $1; }; f"

	# Info
	origin = !"git remote | awk '$1 != \"fork\" {print; exit}'"

	# Undo
	rewrite = !"f() { git rebase --interactive \"HEAD~$1\"; }; f"

	# Pull
	sync = !"f() { \
		git switch --quiet \"$(git default-branch)\" && \
		git pull --prune --no-progress --tags --force && \
		git branch --merged | grep -v $(git default-branch) | xargs -I {} git branch --delete {}; \
	}; f"

	# Clean
	cleanest = clean --force -dx
	cleaning = forgit clean

	# Sync fork
	# https://help.github.com/articles/configuring-a-remote-for-a-fork/
	set-upstream = !"f() { if [ -n \"$1\" ]; then git remote add upstream $1; else echo 'usage: git set-upstream https://github.com/{ORIGINAL_OWNER}/{ORIGINAL_REPOSITORY}.git' && exit 1; fi; }; f"
	# https://help.github.com/articles/syncing-a-fork/
	sync-fork = !"git fetch upstream && git merge \"upstream/$(git default-branch)\" && git push && git sync && git remote prune upstream"

	# Plural
	aliases = config get --all --show-names --regexp '^alias\\.'
	contributors = shortlog --summary --numbered --no-merges
	remotes = remote --verbose
	tags = tag
	tags-remote = ls-remote --tag

[format]
	pretty = %C(auto)%h %Creset%<(72,trunc)%s %Cgreen%<(16,trunc)%aN%Creset %ar%C(auto)%d

[color]
	ui = auto

[color "grep"]
	filename = green ul
	function = dim
	linenumber = dim

[color "diff"]
	meta = cyan bold
	frag = cyan
	old = red bold
	new = green bold

[commit]
	verbose = false
	gpgSign = true

[diff]
	compactionHeuristic = true
	indentHeuristic = true
	algorithm = patience

[pull]
	rebase = true

[rebase]
	autosquash = true

[grep]
	lineNumber = true
	extendedRegexp = true

[protocol]
	version = 2

[blame]
	coloring = highlightRecent

[credential]
	helper = osxkeychain

[init]
	defaultBranch = main

[include]
	path = .gitconfig.local

[push]
	autoSetupRemote = true
	useForceIfIncludes = true
